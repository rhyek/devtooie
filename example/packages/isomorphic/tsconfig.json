{
  "extends": "../../tsconfig.common.json",
  "compilerOptions": {
    // This lib is referenced by other packages, so it's a composite project that emits its
    // compiled output + declarations to `dist` (what consumers import at runtime) — overriding the
    // shared baseline's `noEmit`.
    "noEmit": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "tsconfig.tsbuildinfo"
  },
  "include": ["src"]
}
