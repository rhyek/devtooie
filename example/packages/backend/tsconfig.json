{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "types": ["node"],
    "strict": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  // devtooie reads these project references (no separate tsconfig.build.json) to build
  // @example/isomorphic before this package runs.
  "references": [{ "path": "../isomorphic" }]
}
